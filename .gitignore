# libghostty built by scripts/setup.sh (never committed — no trailing slash, so the
# worktree-convenience symlinks at these paths are ignored too, not just the real dirs)
GhosttyKit.xcframework
agterm/Resources/ghostty
agterm/Resources/terminfo
*.tar.gz

# build artifacts
build/
.build/
agterm.xcodeproj/
.swiftpm/

.DS_Store

# app state / runtime files (only appear if AGTERM_STATE_DIR is pointed at the repo)
settings.json
windows.json
workspaces.json
windows/
*.sock

# track the path-scoped Claude rules (the global ~/.gitignore_global ignores .claude/)
!.claude/
.claude/*
!.claude/rules/
